# Copy this to .env and fill in the values — never commit .env

# Required — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Server port (default 3001)
PORT=3001

# Allowed frontend origin (default http://localhost:5173)
CORS_ORIGIN=http://localhost:5173

# Client — Vite env vars (prefix VITE_ so Vite exposes them to the browser)
VITE_API_URL=http://localhost:3001
